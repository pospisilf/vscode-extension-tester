{
  "name": "extester-runner",
  "displayName": "Extester Runner",
  "description": "Extension for vscode-extension-tester which allow users to run, debug, list tests directly inside VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "ExTester Runner",
      "properties": {
        "extesterRunner.testFileGlob": {
          "type": "string",
          "default": "**/*.test.ts",
          "description": "Glob pattern to find test files in the workspace. Default is '**/*.test.ts'."
        },
        "extesterRunner.excludeGlob": {
          "type": "string",
          "default": "**/node_modules/**",
          "description": "Glob pattern to exclude paths from test file search. Default is '**/node_modules/**'."
        }
      }
    },
    "commands": [
    {
      "command": "extester-runner.refreshTests",
      "title": "Extester Runner: Refresh tests",
      "icon": "$(refresh)",
      "tooltip": "Refresh list of tests" 
    },
    {
      "command": "extester-runner.runAll",
      "title": "Extester Runner: Run all tests",
      "icon": "$(play)",
      "tooltip": "Run all tests"
    }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "extesterRunner",
          "title": "ExTester Runner",
          "icon": "resources/logo.png"
        }
      ]
    },
    "views": {
      "extesterRunner": [
        {
          "id": "extesterView",
          "name": "Test Explorer"
        }
      ]
    },
    "menus": {
    "view/title": [
      {
        "command": "extester-runner.runAll",
        "when": "view == extesterView",
        "group": "navigation"
      },
      {
        "command": "extester-runner.refreshTests",
        "when": "view == extesterView",
        "group": "navigation"
      }
    ]
  }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}